{
  "languages": {
    "rust": {
      "name": "rust-analyzer",
      "command": "rust-analyzer",
      "args": [],
      "file_extensions": [
        "rs"
      ],
      "project_patterns": [
        "Cargo.toml"
      ],
      "exclude_patterns": [
        "**/target/**"
      ],
      "multi_workspace": false,
      "initialization_options": {
        "cargo": {
          "buildScripts": {
            "enable": true
          }
        },
        "diagnostics": {
          "enable": true,
          "enableExperimental": true
        },
        "workspace": {
          "symbol": {
            "search": {
              "scope": "workspace"
            }
          }
        }
      },
      "request_timeout_secs": 60
    }
  }
}